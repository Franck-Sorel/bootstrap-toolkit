# ==============================================================================
# .gitconfig — Global Git configuration
# ==============================================================================
# This file provides sensible defaults. User name and email are set
# separately by config/git.sh (they override the placeholders below).
# ==============================================================================

[user]
    name = Your Name
    email = your.email@example.com

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[color]
    ui = auto

[core]
    editor = nano
    autocrlf = input

[diff]
    algorithm = histogram

[merge]
    conflictstyle = zdiff3

[rerere]
    enabled = true

[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    unstage = reset HEAD --
    last = log -1 HEAD
    visual = !gitk
    lg = log --oneline --graph --decorate --all
    amend = commit --amend --no-edit

[fetch]
    prune = true

[help]
    autocorrect = 10